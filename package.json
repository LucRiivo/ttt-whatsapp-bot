{
  "name": "ttt-whatsapp-tax-bot",
  "version": "1.0.0",
  "description": "WhatsApp Tax Bot powered by OpenAI and Clickatell",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "dev:web": "npm run dev --prefix web",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:web\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "test:webhook": "ts-node test/simulate-webhook.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^3.8.5",
    "@types/pdfkit": "^0.17.4",
    "axios": "^1.13.2",
    "convex": "^1.31.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "openai": "^6.16.0",
    "pdfkit": "^0.17.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
